  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- Mac LocalMods deploy. Replaces the original Windows xcopy/del PostBuildEvent.
       MSBuild <Copy>/<MakeDir> tasks are cross-platform (no shell commands), so
       this works under Mono msbuild and Rider on macOS.
       NOTE: the DLL is still DateFormat.dll until Phase 2 renames the assembly;
       the deploy *folder* is already DateFormatRevisited (folder name and DLL
       name need not match for a CS1 local mod). -->
  <PropertyGroup>
    <ModDeployPath>$(HOME)/Library/Application Support/Colossal Order/Cities_Skylines/Addons/Mods/DateFormatRevisited</ModDeployPath>
  </PropertyGroup>
  <Target Name="DeployMod" AfterTargets="Build">
    <MakeDir Directories="$(ModDeployPath)" />
    <Copy SourceFiles="$(TargetPath)"
          DestinationFolder="$(ModDeployPath)"
          OverwriteReadOnlyFiles="true"
          SkipUnchangedFiles="false" />
    <Copy SourceFiles="$(TargetDir)CitiesHarmony.API.dll"
          DestinationFolder="$(ModDeployPath)"
          OverwriteReadOnlyFiles="true"
          SkipUnchangedFiles="false" />
    <Message Importance="high"
             Text="Deployed $(TargetFileName) + CitiesHarmony.API.dll -&gt; $(ModDeployPath)" />
  </Target>
